// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ENUMS

enum MissionStatus {
  CONCLUIDA
  FALHA
  ABANDONADA
  SELADA
  ANDAMENTO
}

enum AgentStatus {
  ATIVO
  MORTO
  DESAPARECIDO
  CORROMPIDO
  APOSENTADO
}

enum RiskLevel {
  VERY_LOW
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum Privilege {
  RECRUTA
  OPERADOR
  AGENTE_ESPECIAL
  OFICIAL_DE_OPERACOES
  AGENTE_DE_ELITE
}

enum AgentRole {
  COMBATENTE
  ESPECIALISTA
  OCULTISTA
  DESCONHECIDO
}

enum TeamDesignation {
  CONTENCAO
  RECONHECIMENTO
  RESPOSTA_RAPIDA
  SUPORTE
  INVESTIGACAO
}

enum TeamStatus {
  ATIVA
  DISSOLVIDA
  DESAPARECIDA
}

enum ItemType {
  ARMA
  ARTEFATO
  RELIQUIA
  CONSUMIVEL
  OBJETO_COMUM_CORROMPIDO
}

enum ItemStatus {
  CONTIDO
  PERDIDO
  DESTRUIDO
  SELADO
  EM_USO
}

enum OrganizationType {
  SEITA
  CORPORACAO
  CULTO
  FACCAO
  DESCONHECIDA
}

enum OperationScope {
  LOCAL
  REGIONAL
  NACIONAL
  GLOBAL
  DESCONHECIDA
}

enum OrderRelationship {
  ALIADO
  HOSTIL
  NEUTRO
  DESCONHECIDO
  INFILTRADO
}

enum OrganizationStatus {
  ATIVA
  DISSOLVIDA
  EXTINTA
  DESCONHECIDA
}

enum ItemSize {
  SMALL
  MEDIUM
  BIG
}

enum ItemElement {
  MORTE
  ENERGIA
  SANGUE
  CONHECIMENTO
  MEDO
  DESCONHECIDO
}

// MODELS

model Team {
  id          String          @map("_id") @id @default(auto()) @db.ObjectId
  name        String

  designation TeamDesignation
  status      TeamStatus
  
  agents      AgentTeam[]
  cases       TeamCases[]

  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
}

model Agent {
  id          String      @map("_id") @id @default(auto()) @db.ObjectId
  name        String
  image       String?
  role        AgentRole
  status      AgentStatus             @default(ATIVO)
  accessLevel Privilege               @default(RECRUTA)

  lore        String?

  teams       AgentTeam[]

  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
}

model Occultist {
  id          String           @map("_id") @id @default(auto()) @db.ObjectId
  name        String
  status      AgentStatus                  @default(ATIVO)
  accessLevel Privilege                    @default(RECRUTA)
  image       String?
  lore        String?
  cases       OccultistCases[]
}

  model Items {
  id            String      @map("_id") @id @default(auto()) @db.ObjectId
  name          String
  image         String?
  type          ItemType
  size          ItemSize
accessLevel Privilege               @default(RECRUTA)
  elements      ItemElement             @default(DESCONHECIDO)
  description   String?
  containment   String?
  extra_notes   String?

  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
}

model Organization {
  id           String             @map("_id") @id @default(auto()) @db.ObjectId

  name         String

  type         OrganizationType               @default(DESCONHECIDA)
  scope        OperationScope

  ideology     String?
  accessLevel  Privilege                      @default(RECRUTA)
  threatLevel  RiskLevel
  relationship OrderRelationship

  status       OrganizationStatus

  createdAt    DateTime                       @default(now())
  updatedAt    DateTime                       @updatedAt
}

model Cases {
  id                String           @map("_id") @id @default(auto()) @db.ObjectId
  name              String
  description       String
  accessLevel       Privilege                    @default(RECRUTA)
  occultists        OccultistCases[]
  teams             TeamCases[]
  }

  // RELATION TABLES

  model AgentTeam {
  id                String           @map("_id") @id @default(auto()) @db.ObjectId

  agentId           String                       @db.ObjectId
  agent             Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)

  teamId            String                       @db.ObjectId
  team              Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)

  joinedAt          DateTime                     @default(now())

  @@unique([agentId, teamId])
  @@index([agentId])
  @@index([teamId])
}

model OccultistCases  {
  id          String    @map("_id") @id @default(auto()) @db.ObjectId

  occultistId String                @db.ObjectId
  occultist   Occultist @relation(fields: [occultistId], references: [id], onDelete: Cascade)

  casesId     String                @db.ObjectId
  cases       Cases     @relation(fields: [casesId], references: [id], onDelete: Cascade)

  @@unique([occultistId, casesId])
  @@index([occultistId])
  @@index([casesId])
}

model TeamCases {
  id         String   @map("_id") @id @default(auto()) @db.ObjectId

  teamId     String               @db.ObjectId
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  caseId     String               @db.ObjectId
  case       Cases    @relation(fields: [caseId], references: [id], onDelete: Cascade)

  assignedAt DateTime             @default(now())

  @@unique([teamId, caseId])
  @@index([teamId])
  @@index([caseId])
}